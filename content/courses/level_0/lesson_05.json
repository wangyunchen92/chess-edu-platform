  "steps": [
    {
      "type": "dialogue",
      "character": "xiaoqi",
      "expression": "happy",
      "content": "豆丁老师，上次学了兵的走法，今天学什么呢？"
    },
    {
      "type": "dialogue",
      "character": "douding",
      "expression": "happy",
      "content": "今天学两个厉害的大棋子——车和象！它们都能走好远好远哦。"
    },
    {
      "type": "dialogue",
      "character": "xiaoqi",
      "expression": "surprised",
      "content": "走好远？比兵厉害多了吧？"
    },
    {
      "type": "dialogue",
      "character": "douding",
      "expression": "happy",
      "content": "那当然！车沿直线走，横着竖着都行，想走多远走多远。象沿对角线走，也是想走多远走多远！不过它们都不能跳过别的棋子。"
    },
    {
      "type": "dialogue",
      "character": "xiaoqi",
      "expression": "thinking",
      "content": "那车和象谁更厉害呀？"
    },
    {
      "type": "dialogue",
      "character": "douding",
      "expression": "thinking",
      "content": "车值5分，象值3分，所以车更厉害一些。来看看车有多威风吧！"
    },
    {
      "type": "board_demo",
      "character": "douding",
      "expression": "surprised",
      "fen": "8/8/8/8/3R4/8/8/8 w - - 0 1",
      "description": "哇！看看车在d4有多厉害！它可以沿着d列上下走（d1-d8），也可以沿着第4行左右走（a4-h4）。车从d4可以到达14个不同的格子呢！",
      "highlights": [
