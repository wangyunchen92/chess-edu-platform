      "question": "棋盘的列用什么表示？",
      "options": ["数字1-8", "字母a-h", "罗马数字", "中文数字"],
      "correct": 1
    },
    {
      "type": "choice",
      "question": "棋盘的\"中心\"是指哪4个格子？",
      "options": ["a1, a2, b1, b2", "d4, d5, e4, e5", "d1, d8, e1, e8", "a4, a5, h4, h5"],
      "correct": 1
    }
  ]
}