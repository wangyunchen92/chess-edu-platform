# Database
DATABASE_URL=postgresql+asyncpg://chess_user:chess_pass@localhost:5432/chess_edu
DATABASE_URL_SYNC=postgresql://chess_user:chess_pass@localhost:5432/chess_edu

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=your-256-bit-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# LLM (火山引擎，选型待定)
LLM_API_KEY=your_api_key
LLM_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL_REVIEW=doubao-pro-xxxxx
LLM_MODEL_SIMPLE=doubao-lite-xxxxx
LLM_MONTHLY_BUDGET_CNY=1000

# OSS
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=chess-edu
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# App
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
